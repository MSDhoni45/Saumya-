# Copy to .env.local for local development.

# --- Supabase (browser/server clients use the public anon key — RLS enforces
# tenant isolation, so this key is safe to expose) -------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-anon-public-key

# --- FastAPI backend (server-side only — proxied to the browser via
# next.config.ts rewrites so cookies stay first-party) ----------------------
BACKEND_API_URL=http://localhost:8000
