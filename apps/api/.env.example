# Copy to .env for local development. In staging/production these are provided
# as platform secrets — never commit a real .env file.

# --- App -----------------------------------------------------------------
ENVIRONMENT=local                 # local | staging | production
DEBUG=true
APP_NAME=WhatsAgent AI API
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:3000

# --- Database (Supabase Postgres, async SQLAlchemy + asyncpg) -------------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/whatsagent

# --- Redis (Celery broker/result backend + caching) -----------------------
REDIS_URL=redis://localhost:6379/0

# --- Supabase (Auth: GoTrue REST for signup/login/reset, JWKS for JWT validation) -
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_ANON_KEY=replace-with-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_JWT_ISSUER=https://your-project.supabase.co/auth/v1

# --- Auth session cookies (httpOnly cookies the backend issues to the SPA) -
AUTH_ACCESS_TOKEN_COOKIE=wa_access_token
AUTH_REFRESH_TOKEN_COOKIE=wa_refresh_token
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_SECURE=true

# --- AI providers (provider-agnostic orchestration layer) -----------------
OPENAI_API_KEY=replace-with-openai-key
ANTHROPIC_API_KEY=replace-with-anthropic-key

# --- WhatsApp Cloud API (Meta) ---------------------------------------------
WHATSAPP_APP_ID=replace-with-meta-app-id
WHATSAPP_APP_SECRET=replace-with-meta-app-secret
WHATSAPP_WEBHOOK_VERIFY_TOKEN=replace-with-webhook-verify-token
WHATSAPP_GRAPH_API_VERSION=v21.0

# --- Google Calendar (OAuth2) -----------------------------------------------
GOOGLE_OAUTH_CLIENT_ID=replace-with-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/calendar/oauth/callback

# --- Secrets encryption (at-rest encryption for stored OAuth/API tokens) --
TOKEN_ENCRYPTION_KEY=replace-with-32-byte-fernet-key

# --- LLM cross-provider fallback ------------------------------------------
LLM_FALLBACK_ENABLED=false
FALLBACK_OPENAI_MODEL=gpt-4o-mini
FALLBACK_ANTHROPIC_MODEL=claude-sonnet-4-5
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# --- Observability -----------------------------------------------------------
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# --- Stripe (billing) -------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_GROWTH_PRICE_ID=
STRIPE_AGENCY_PRICE_ID=

# --- Razorpay (billing — India) ---------------------------------------------
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_STARTER_PLAN_ID=
RAZORPAY_GROWTH_PLAN_ID=
RAZORPAY_AGENCY_PLAN_ID=

# --- Email (transactional — invites, notifications) -----------------------
SENDGRID_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
EMAIL_FROM_ADDRESS=noreply@whatsagent.ai
EMAIL_FROM_NAME=WhatsAgent AI

# --- Frontend ---------------------------------------------------------------
APP_FRONTEND_URL=http://localhost:3000
